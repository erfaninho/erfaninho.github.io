# Vite exposes variables prefixed with VITE_ to the browser bundle (not private).
VITE_SITE_TITLE="Your Name"
VITE_PROFILE_IMAGE_URL="placeholders/profile.svg"
VITE_GITHUB_REPO_URL="https://github.com/yourname/yourrepo"
VITE_GITHUB_PROFILE_URL="https://github.com/yourname"
VITE_LINKEDIN_URL="https://www.linkedin.com/in/yourname/"
VITE_CONTACT_EMAIL="you@example.com"

# API Caller (client-side; do not put secrets here)
# Comma-separated model ids shown in the dropdown.
VITE_API_MODELS="gemini-2.5-flash-lite,gemini-2.0-flash,gemini-1.5-flash"
# Endpoint template; supports {model} placeholder.
VITE_API_ENDPOINT_TEMPLATE="https://example.com/api/{model}"
